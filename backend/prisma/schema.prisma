// ============================================
// ProjectMeet - Prisma Schema
// ============================================
// Replace DATABASE_URL in .env to point to any
// PostgreSQL instance (local Docker, AWS RDS, etc.)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// User
// ============================================
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  displayName   String   @map("display_name")
  avatarUrl     String?  @map("avatar_url")
  isActive      Boolean  @default(true) @map("is_active")
  role          UserRole @default(USER)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sessions      Session[]
  meetingsOwned Meeting[]        @relation("MeetingOwner")
  participants  MeetingParticipant[]
  messages      Message[]
  chatMembers   ChatMember[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

// ============================================
// Session (for refresh tokens / session mgmt)
// ============================================
model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  userAgent    String?  @map("user_agent")
  ipAddress    String?  @map("ip_address")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ============================================
// Meeting
// ============================================
model Meeting {
  id           String        @id @default(uuid())
  code         String        @unique // e.g., "abc-defg-hij"
  title        String
  description  String?
  ownerId      String        @map("owner_id")
  status       MeetingStatus @default(SCHEDULED)
  scheduledAt  DateTime?     @map("scheduled_at")
  startedAt    DateTime?     @map("started_at")
  endedAt      DateTime?     @map("ended_at")
  maxParticipants Int        @default(100) @map("max_participants")
  isRecording  Boolean       @default(false) @map("is_recording")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  owner        User                 @relation("MeetingOwner", fields: [ownerId], references: [id])
  participants MeetingParticipant[]
  chat         Chat?

  @@index([code])
  @@index([ownerId])
  @@map("meetings")
}

enum MeetingStatus {
  SCHEDULED
  ACTIVE
  ENDED
  CANCELLED
}

// ============================================
// MeetingParticipant
// ============================================
model MeetingParticipant {
  id        String              @id @default(uuid())
  meetingId String              @map("meeting_id")
  userId    String              @map("user_id")
  role      ParticipantRole     @default(PARTICIPANT)
  joinedAt  DateTime            @default(now()) @map("joined_at")
  leftAt    DateTime?           @map("left_at")
  isAudioOn Boolean             @default(true) @map("is_audio_on")
  isVideoOn Boolean             @default(true) @map("is_video_on")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
  @@map("meeting_participants")
}

enum ParticipantRole {
  HOST
  CO_HOST
  PARTICIPANT
}

// ============================================
// Chat (linked to a meeting or standalone)
// ============================================
model Chat {
  id        String     @id @default(uuid())
  meetingId String?    @unique @map("meeting_id")
  type      ChatType   @default(GROUP)
  name      String?
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  meeting  Meeting?     @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  members  ChatMember[]
  messages Message[]

  @@map("chats")
}

enum ChatType {
  DIRECT
  GROUP
}

// ============================================
// ChatMember
// ============================================
model ChatMember {
  id       String   @id @default(uuid())
  chatId   String   @map("chat_id")
  userId   String   @map("user_id")
  joinedAt DateTime @default(now()) @map("joined_at")

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([chatId])
  @@index([userId])
  @@map("chat_members")
}

// ============================================
// Message
// ============================================
model Message {
  id        String      @id @default(uuid())
  chatId    String      @map("chat_id")
  senderId  String      @map("sender_id")
  content   String
  type      MessageType @default(TEXT)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  chat   Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([senderId])
  @@map("messages")
}

enum MessageType {
  TEXT
  SYSTEM
  FILE
}
