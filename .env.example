# ============================================
# ProjectMeet - Environment Configuration
# ============================================
# Copy this file to .env and fill in your own values.
# IMPORTANT: Never commit .env to version control!
# Replace these values for local development and production/cloud deployment.

# Database
POSTGRES_USER=projectmeet
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=projectmeet
DATABASE_URL=postgresql://projectmeet:your_secure_password_here@postgres:5432/projectmeet?schema=public

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-value
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-value
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Backend
BACKEND_PORT=4003
NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4003/api
NEXT_PUBLIC_WS_URL=http://localhost:4003
NEXT_PUBLIC_APP_NAME=ProjectMeet

# TURN/STUN Server
TURN_SERVER_URL=turn:localhost:3478
TURN_USERNAME=projectmeet
TURN_PASSWORD=your_turn_server_password_here
STUN_SERVER_URL=stun:stun.l.google.com:19302

# Coturn
TURN_REALM=projectmeet.local
TURN_MIN_PORT=49152
TURN_MAX_PORT=65535
